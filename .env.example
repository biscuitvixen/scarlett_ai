# Discord bot token from https://discord.com/developers/applications
# The bot needs the "message content" privileged intent enabled.
DISCORD_TOKEN=

# Optional. If set, slash commands sync to this guild instantly instead of
# taking up to an hour to propagate globally. Handy while developing.
GUILD_ID=

# The bot talks to any OpenAI-compatible endpoint. Defaults point at the
# vllm service in docker-compose.yml (start it with --profile llm).
LLM_BASE_URL=http://vllm:8000/v1
LLM_MODEL=Qwen/Qwen3-32B
LLM_API_KEY=not-needed

# Only needed if the model repo on Hugging Face is gated.
HF_TOKEN=

# Fraction of GPU memory vllm may claim. Memory is unified on the Spark,
# leave headroom for the OS and the other containers.
GPU_MEM_UTIL=0.70

# Guild ids (comma separated) where the chat personality is allowed to
# talk. She stays silent everywhere else; timestamps work everywhere.
CHAT_GUILD_IDS=

# Her personality prompt, edit the file and the next reply uses it.
PERSONALITY_PATH=/app/personality.md

# Lavalink audio server. Password must match lavalink/application.yml.
LAVALINK_URL=http://lavalink:2333
LAVALINK_PASSWORD=youshallnotpass
