# Discord bot token from https://discord.com/developers/applications
# The bot needs the "message content" privileged intent enabled.
DISCORD_TOKEN=

# Optional. If set, slash commands sync to this guild instantly instead of
# taking up to an hour to propagate globally. Handy while developing.
GUILD_ID=

# The bot talks to any OpenAI-compatible endpoint, so vllm can run wherever.
# Three deployment modes:
#   1. No LLM (GPU-less box): LLM_ENABLED=false. Timestamps and music still
#      work, she just never chats and the chat cog is not loaded.
#   2. Query a remote Spark: LLM_ENABLED=true and point LLM_BASE_URL at it,
#      e.g. http://spark.local:8000/v1. Start only vllm on the Spark with
#      `docker compose --profile llm up -d vllm`.
#   3. All on the Spark: LLM_ENABLED=true, keep the default LLM_BASE_URL, and
#      bring up everything with `docker compose --profile llm up -d`.
LLM_ENABLED=true
LLM_BASE_URL=http://vllm:8000/v1
LLM_MODEL=Qwen/Qwen3-32B-AWQ
# vllm ignores this unless started with --api-key. If you expose port 8000
# beyond a trusted LAN/VPN, set a secret here and add --api-key to vllm.
LLM_API_KEY=not-needed

# Only needed if the model repo on Hugging Face is gated.
HF_TOKEN=

# Fraction of GPU memory vllm may claim. Memory is unified on the Spark,
# leave headroom for the OS and the other containers.
GPU_MEM_UTIL=0.70

# Guild ids (comma separated) where the chat personality is allowed to
# talk. She stays silent everywhere else; timestamps work everywhere.
CHAT_GUILD_IDS=

# User ids (comma separated) exempt from every chat rate limit, i.e. you.
# Turn on Discord Developer Mode (Settings > Advanced), then right click your
# name and "Copy User ID".
OWNER_IDS=

# How hard friends can lean on her. Everyone except OWNER_IDS is limited to
# one reply per CHAT_USER_COOLDOWN seconds and CHAT_USER_HOURLY_CAP replies
# per rolling hour. Being throttled earns one terse reply then silence.
CHAT_USER_COOLDOWN=10
CHAT_USER_HOURLY_CAP=20
# Generations allowed at once; a burst queues rather than dogpiling the gpu.
CHAT_MAX_CONCURRENT=2
# Caps (characters) on the chat history fed to the model, per line and total,
# so a pasted wall of text can't blow up the prompt.
CHAT_LINE_CHAR_CAP=500
CHAT_TRANSCRIPT_CHAR_CAP=4000

# Her personality prompt, edit the file and the next reply uses it.
PERSONALITY_PATH=/app/personality.md

# Lavalink audio server. Password must match lavalink/application.yml.
LAVALINK_URL=http://lavalink:2333
LAVALINK_PASSWORD=youshallnotpass
